    "imagen": {
      "model": "imagen-3.0-generate-001",
      "secret": "GOOGLE_IMAGEN_API_KEY",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/imagen-3.0-generate-001:predict",
